# ──────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores antes de rodar o sistema.
# NUNCA versione o .env com dados reais.
# ──────────────────────────────────────────────────────────────────────────────

# URL pública da API C# (usada pelo frontend)
NEXT_PUBLIC_API_URL=http://localhost/api

# PostgreSQL
POSTGRES_DB=gestao_locacoes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_FORTE

# Connection string para o backend C# (Entity Framework / Npgsql)
DB_CONNECTION_STRING=Host=db;Port=5432;Database=gestao_locacoes;Username=postgres;Password=TROQUE_ESTA_SENHA_FORTE

# Secrets da aplicação (gere valores aleatórios em produção)
JWT_SECRET=TROQUE_ESTE_SECRET_JWT_32_CARACTERES_MINIMO
